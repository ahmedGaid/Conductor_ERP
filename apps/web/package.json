{
  "name": "erp-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "ERP frontend — React + TS + Vite, Arabic/RTL-first, i18n key-parity enforced.",
  "scripts": {
    "dev": "vite",
    "check:i18n": "node scripts/check-i18n-parity.mjs",
    "typecheck": "tsc --noEmit",
    "prebuild": "node scripts/check-i18n-parity.mjs",
    "build": "tsc -b && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@fontsource/ibm-plex-sans-arabic": "^5.1.0",
    "@fontsource/inter": "^5.1.0",
    "@xyflow/react": "^12.3.6",
    "i18next": "^24.2.0",
    "i18next-browser-languagedetector": "^8.0.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^15.4.0",
    "react-router-dom": "^7.1.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.7.2",
    "vite": "^6.0.7"
  }
}
