###############################################################################
# Conductor ERP — Docker environment template (hybrid deploy).
#
# Copy to `.env` next to docker-compose.yml and fill every value:
#     cp .env.docker.example .env
#
# Single-tenant, customer-hosted: the customer owns every secret here.
# The SAME file drives a cloud VPS and an on-prem box — only the values differ
# (see BACKUP_DESTINATION + the HTTPS block).  `.env` is gitignored; never commit it.
###############################################################################

# ── Django core ─────────────────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=config.settings.prod
# Generate ONE strong unique key (rotating it logs everyone out):
#   docker compose run --rm web python -c "from django.core.management.utils import get_random_secret_key as g; print(g())"
DJANGO_SECRET_KEY=CHANGE-ME-to-a-50+-char-random-secret
DJANGO_DEBUG=false
# Every hostname/IP the server answers on. Keep localhost for the healthcheck.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,erp.example.com
# Optional extra IP whitelist (comma-separated CIDRs/IPs). Empty = allow all.
DJANGO_IP_WHITELIST=

# ── HTTPS / reverse proxy ───────────────────────────────────────────────────
# DEFAULTS BELOW ARE FOR AN HTTP-ONLY install (TLS terminated by your own proxy,
# or a flat on-prem LAN). When you terminate TLS *in front* of this stack, flip
# all three to true and set CSRF trusted origins to your https origin.
DJANGO_SSL_REDIRECT=false
DJANGO_COOKIE_SECURE=false
DJANGO_HSTS_SECONDS=0
DJANGO_CSRF_TRUSTED_ORIGINS=
# Only if the SPA is served from a DIFFERENT origin than the API (it isn't, by default).
DJANGO_CORS_ALLOWED_ORIGINS=

# ── Database (PostgreSQL 16) ────────────────────────────────────────────────
# Host is the compose service name `db`. The three POSTGRES_* values seed the
# db container and MUST match the credentials inside DATABASE_URL.
POSTGRES_DB=erp
POSTGRES_USER=erp
POSTGRES_PASSWORD=CHANGE-ME-strong-db-password
DATABASE_URL=postgresql://erp:CHANGE-ME-strong-db-password@db:5432/erp

# ── Redis (Celery broker + result backend) ──────────────────────────────────
# Host is the compose service name `redis`.
REDIS_URL=redis://redis:6379/0
CELERY_TASK_ALWAYS_EAGER=false

# ── Rate limiting (in-code defaults shown) ──────────────────────────────────
DRF_THROTTLE_ANON=60/min
DRF_THROTTLE_USER=1000/min

# ── File / document storage ─────────────────────────────────────────────────
# Inside the container; mapped to the `storage_data` volume in compose.
STORAGE_ROOT=/app/storage

# ── Backups: LOCAL (on-prem) vs S3 (cloud) ──────────────────────────────────
# LOCAL → dump to BACKUP_LOCAL_DIR (mount it to durable/offsite storage).
# S3    → push the dump to an S3-compatible bucket (cloud deployments).
BACKUP_DESTINATION=LOCAL
BACKUP_LOCAL_DIR=/app/storage/backups
# Only used when BACKUP_DESTINATION=S3:
BACKUP_S3_BUCKET=
BACKUP_S3_ENDPOINT_URL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=

# ── ETA e-invoicing adapter ─────────────────────────────────────────────────
# Pre-production = Egyptian Tax Authority sandbox; Production = live filing.
ETA_ENVIRONMENT=Pre-production
ETA_CLIENT_ID=
ETA_CLIENT_SECRET=

# ── Email (SMTP). Default is the offline console backend. ────────────────────
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=true
DEFAULT_FROM_EMAIL=conductor@example.com

# ── App identity / host port mapping ────────────────────────────────────────
APP_VERSION=1.0.0
# Host port published for the web container (container port is always 8000).
API_PORT=8000
