# Copy to .env and adjust for the local/customer environment.
# Customer-hosted, single-tenant: every value is owned by the customer.

# --- Django ---
DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_SECRET_KEY=dev-insecure-change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# Comma-separated CIDRs/IPs allowed to reach the API (IP whitelisting). Empty = allow all (dev only).
DJANGO_IP_WHITELIST=

# --- Database (PostgreSQL 16) ---
DATABASE_URL=postgresql://erp:erp@localhost:5432/erp
# The simulated external ERP target used by the workflow SQL adapter lives in the
# same instance under schema "erp_external" (created by a migration), no second server.

# --- Redis / Memurai (Celery broker + result backend) ---
REDIS_URL=redis://localhost:6379/0

# --- Celery ---
CELERY_TASK_ALWAYS_EAGER=false

# --- File / document storage (Machine 3 in multi-machine topology) ---
STORAGE_ROOT=./storage

# --- App identity / versioning ---
APP_VERSION=0.0.0
API_PORT=8000
WEB_PORT=5173

# --- Default dev user (replaced by real auth in Stage 1) ---
DEV_USER_EMAIL=ahmedgaid85@gmail.com
DEV_USER_NAME=Dev User
