# Keep the build context small and the image clean / reproducible.

# Python
.venv/
**/__pycache__/
*.pyc
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Frontend — node_modules and a stale dist are rebuilt inside the image.
apps/web/node_modules/
apps/web/dist/

# Collected static is regenerated by collectstatic at container start.
staticfiles/

# Local runtime data must never bake into the image.
storage/
files/
files.zip
temp/

# Secrets / local env (only the *.example templates ship).
.env
.env.*
!.env.example
!.env.docker.example

# VCS / IDE / OS noise
.git/
.gitignore
.idea/
.vscode/
*.log
