# Conductor ERP — PRODUCTION environment template (Phase 11).
# Copy to the repo root as `.env` on the server (it is gitignored) and fill every value.
# Single-tenant, customer-hosted: the customer owns every secret here. Never commit a real .env.

# --- Django ---
DJANGO_SETTINGS_MODULE=config.settings.prod
# Generate ONE strong unique key and keep it secret (50+ random chars). Rotating it logs everyone out.
#   python -c "from django.core.management.utils import get_random_secret_key as g; print(g())"
DJANGO_SECRET_KEY=CHANGE-ME-to-a-50+-char-random-secret
DJANGO_DEBUG=false
# Every hostname/IP the server answers on (comma-separated). Requests to other hosts are rejected.
DJANGO_ALLOWED_HOSTS=erp.example.com
# Comma-separated CIDRs/IPs allowed to reach the API (extra IP whitelisting). Empty = allow all.
DJANGO_IP_WHITELIST=

# --- HTTPS / reverse proxy ---
# These default to SECURE in prod; relax ONLY for a deliberate HTTP-only internal install.
DJANGO_SSL_REDIRECT=true
DJANGO_COOKIE_SECURE=true
DJANGO_HSTS_SECONDS=31536000
# Full public origins (scheme + host) that may send unsafe (POST/PUT/DELETE) requests.
DJANGO_CSRF_TRUSTED_ORIGINS=https://erp.example.com
# Only needed if the SPA is hosted on a DIFFERENT origin than the API (it isn't, by default).
DJANGO_CORS_ALLOWED_ORIGINS=

# --- Database (PostgreSQL 16) ---
DATABASE_URL=postgresql://erp:CHANGE-ME@localhost:5432/erp

# --- Redis (Celery broker + result backend) ---
REDIS_URL=redis://localhost:6379/0
CELERY_TASK_ALWAYS_EAGER=false

# --- Rate limiting (env-tunable; these are the in-code defaults) ---
DRF_THROTTLE_ANON=60/min
DRF_THROTTLE_USER=1000/min

# --- File / document storage (keep OFF the OS drive if possible; included in backups) ---
STORAGE_ROOT=C:/ConductorData/storage

# --- Email (SMTP for real outbound notifications; default is the offline console backend) ---
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=true
DEFAULT_FROM_EMAIL=conductor@example.com

# --- App identity ---
APP_VERSION=1.0.0
API_PORT=8000
WEB_PORT=5173
